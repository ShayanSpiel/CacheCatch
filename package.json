{
  "name": "cachecatch",
  "version": "0.4.15",
  "description": "Prompt-cache audit CLI for AI agents — find cache breakers, estimate recoverable spend, and share your 𝕏 banner.",
  "repository": {
    "type": "git",
    "url": "https://github.com/ShayanSpiel/CacheCatch.git"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "cachecatch": "dist/index.js"
  },
  "files": [
    "dist",
    "scripts",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build:cli": "tsc -p tsconfig.cli.json && node scripts/postbuild-cli.mjs",
    "build:web": "next build",
    "build": "npm run build:cli && npm run build:web",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "cli": "npm run build:cli && node dist/index.js",
    "cachecatch": "npm run build:cli && node dist/index.js",
    "test": "npm run build:cli && tsc -p tsconfig.test.json && node dist-test/src/engine/__tests__/engine.test.js && node dist-test/src/adapters/__tests__/adapters.test.js && node dist-test/src/adapters/__tests__/http-plumbing.test.js && node dist-test/src/bin/__tests__/cli.test.js",
    "test:live": "tsc -p tsconfig.test.json && node dist-test/src/adapters/__tests__/live.test.js",
    "postinstall": "node scripts/postinstall.mjs",
    "prepublishOnly": "npm run build:cli"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "@puppeteer/browsers": "^2.13.2",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "clipboardy": "^5.3.1",
    "commander": "^15.0.0",
    "ora": "^9.4.1",
    "puppeteer-core": "^24.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "remixicon-react": "^1.0.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
